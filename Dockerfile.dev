FROM rust:1.82-bookworm

# System dependencies
RUN apt-get update && apt-get install -y \
    postgresql-client \
    libssl-dev \
    pkg-config \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Rust tools
RUN cargo install sqlx-cli --no-default-features --features postgres \
    && cargo install cargo-tarpaulin \
    && rustup component add clippy rustfmt

# Node.js for frontend
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

WORKDIR /app

# Pre-cache dependencies
COPY Cargo.toml Cargo.lock ./
COPY crates/domain/Cargo.toml crates/domain/Cargo.toml
COPY crates/application/Cargo.toml crates/application/Cargo.toml
COPY crates/infrastructure/Cargo.toml crates/infrastructure/Cargo.toml
RUN mkdir -p crates/domain/src crates/application/src crates/infrastructure/src \
    && echo "fn main() {}" > crates/domain/src/lib.rs \
    && echo "fn main() {}" > crates/application/src/lib.rs \
    && echo "fn main() {}" > crates/infrastructure/src/lib.rs \
    && mkdir -p crates/infrastructure/src/bin \
    && echo "fn main() {}" > crates/infrastructure/src/bin/server.rs \
    && cargo build 2>/dev/null || true \
    && rm -rf crates/*/src

# Copy full source
COPY . .

ENV SQLX_OFFLINE=true
ENV DATABASE_URL=postgres://banko:banko@postgres:5432/banko

CMD ["cargo", "test"]
