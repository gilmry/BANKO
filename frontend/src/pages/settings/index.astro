---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Paramètres">
  <!-- Settings Navigation -->
  <div data-testid="page-settings" class="grid gap-8 lg:grid-cols-4">
    <!-- Settings Sidebar -->
    <nav data-testid="settings-nav" class="lg:col-span-1">
      <div class="rounded-lg border border-gray-200 bg-white shadow-sm overflow-hidden">
        <a href="#general" data-testid="settings-nav-general" class="block px-4 py-3 text-sm font-medium text-blue-700 bg-blue-50 border-l-4 border-blue-600">Général</a>
        <a href="#security" data-testid="settings-nav-security" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 border-l-4 border-transparent">Sécurité</a>
        <a href="#notifications" data-testid="settings-nav-notifications" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 border-l-4 border-transparent">Notifications</a>
        <a href="#api" data-testid="settings-nav-api" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 border-l-4 border-transparent">API & Intégrations</a>
        <a href="#compliance" data-testid="settings-nav-compliance" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 border-l-4 border-transparent">Conformité</a>
        <a href="#system" data-testid="settings-nav-system" class="block px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 border-l-4 border-transparent">Système</a>
      </div>
    </nav>

    <!-- Settings Content -->
    <div class="lg:col-span-3 space-y-8">
      <!-- General Settings -->
      <section id="general" data-testid="settings-general-section" class="rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 data-testid="settings-general-heading" class="text-lg font-semibold text-gray-900">Paramètres généraux</h2>
          <p class="mt-1 text-sm text-gray-500">Configuration de base de la plateforme BANKO.</p>
        </div>
        <div class="p-6 space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nom de l'institution</label>
            <input type="text" value="BANKO - Core Banking Platform" data-testid="settings-institution-name" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-blue-500 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Devise par défaut</label>
            <select data-testid="settings-currency-select" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm">
              <option value="TND" selected>TND - Dinar tunisien</option>
              <option value="EUR">EUR - Euro</option>
              <option value="USD">USD - Dollar américain</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Langue par défaut</label>
            <select data-testid="settings-language-select" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm">
              <option value="fr" selected>Français</option>
              <option value="ar">العربية</option>
              <option value="en">English</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fuseau horaire</label>
            <select data-testid="settings-timezone-select" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm">
              <option value="Africa/Tunis" selected>Africa/Tunis (UTC+1)</option>
              <option value="Europe/Paris">Europe/Paris (UTC+2)</option>
            </select>
          </div>
        </div>
      </section>

      <!-- Security Settings -->
      <section id="security" data-testid="settings-security-section" class="rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 data-testid="settings-security-heading" class="text-lg font-semibold text-gray-900">Sécurité</h2>
          <p class="mt-1 text-sm text-gray-500">Paramètres de sécurité et authentification.</p>
        </div>
        <div class="p-6 space-y-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-medium text-gray-900">Authentification à deux facteurs (2FA)</p>
              <p class="text-sm text-gray-500">Exiger la 2FA pour tous les utilisateurs.</p>
            </div>
            <button data-testid="settings-2fa-toggle" class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-blue-600 transition-colors" role="switch" aria-checked="true">
              <span class="translate-x-5 inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition"></span>
            </button>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="font-medium text-gray-900">Expiration des sessions</p>
              <p class="text-sm text-gray-500">Durée maximale d'inactivité avant déconnexion.</p>
            </div>
            <select data-testid="settings-session-expiry" class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm">
              <option value="15">15 minutes</option>
              <option value="30" selected>30 minutes</option>
              <option value="60">1 heure</option>
            </select>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="font-medium text-gray-900">Politique de mots de passe</p>
              <p class="text-sm text-gray-500">Exigences minimales pour les mots de passe.</p>
            </div>
            <span class="text-sm text-green-600 font-medium">Fort (12+ car.)</span>
          </div>
        </div>
      </section>

      <!-- System Info -->
      <section id="system" data-testid="settings-system-section" class="rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 data-testid="settings-system-heading" class="text-lg font-semibold text-gray-900">Informations système</h2>
        </div>
        <div class="p-6">
          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-lg bg-gray-50 p-4">
              <p class="text-sm text-gray-500">Version</p>
              <p class="font-mono font-medium text-gray-900">BANKO v0.1.0-alpha</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-4">
              <p class="text-sm text-gray-500">Backend</p>
              <p class="font-mono font-medium text-gray-900">Rust + Actix-web 4.x</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-4">
              <p class="text-sm text-gray-500">Base de données</p>
              <p class="font-mono font-medium text-gray-900">PostgreSQL 16</p>
            </div>
            <div class="rounded-lg bg-gray-50 p-4">
              <p class="text-sm text-gray-500">Licence</p>
              <p class="font-mono font-medium text-gray-900">AGPL-3.0</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</DashboardLayout>
