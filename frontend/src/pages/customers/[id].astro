---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import StatusBadge from '@/components/common/StatusBadge.svelte';

const { id } = Astro.params;

// Sample data - in production, this would come from the API
const customer = {
  id,
  first_name: 'Ahmed',
  last_name: 'Ben Ali',
  email: 'ahmed.benali@email.com',
  phone: '+216 20 123 456',
  date_of_birth: '1985-05-15',
  gender: 'male',
  cin: '07645826',
  nationality: 'Tunisienne',
  kyc_status: 'approved' as const,
  customer_type: 'individual' as const,
  created_at: '2026-03-15T10:30:00Z',
  accounts: [
    {
      id: 'acc1',
      account_type: 'checking',
      account_number: 'FR76 0000 0000 0000 0000 0000 000',
      balance: { amount: 15000, currency: 'TND' },
      status: 'active',
    },
    {
      id: 'acc2',
      account_type: 'savings',
      account_number: 'FR76 0000 0000 0000 0000 0000 001',
      balance: { amount: 50000, currency: 'TND' },
      status: 'active',
    },
  ],
};
---

<DashboardLayout
  title={`${customer.first_name} ${customer.last_name}`}
  breadcrumb={[
    { label: 'Clients', href: '/customers' },
    { label: `${customer.first_name} ${customer.last_name}` },
  ]}
>
  <div class="grid gap-6">
    <!-- Customer Info Card -->
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            {customer.first_name}
            {customer.last_name}
          </h1>
          <p class="mt-1 text-gray-600">{customer.email}</p>
        </div>
        <div>
          <StatusBadge client:load status={customer.kyc_status} />
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Personal Information -->
        <div>
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Informations Personnelles</h2>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-gray-600">Téléphone</dt>
              <dd class="font-medium text-gray-900">{customer.phone}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Date de naissance</dt>
              <dd class="font-medium text-gray-900">
                {new Date(customer.date_of_birth).toLocaleDateString('fr-FR')}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">Nationalité</dt>
              <dd class="font-medium text-gray-900">{customer.nationality}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600">CIN</dt>
              <dd class="font-medium text-gray-900 font-mono">{customer.cin}</dd>
            </div>
          </dl>
        </div>

        <!-- Account Information -->
        <div>
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Comptes Associés</h2>
          <div class="space-y-2">
            {customer.accounts.map((account) => (
              <div class="rounded border border-gray-200 p-3">
                <p class="text-sm font-medium text-gray-900 capitalize">{account.account_type}</p>
                <p class="text-xs text-gray-500 font-mono">{account.account_number}</p>
                <div class="mt-2 flex justify-between items-center">
                  <span class="text-sm font-semibold text-gray-900">
                    {new Intl.NumberFormat('fr-TN', { style: 'currency', currency: 'TND' }).format(account.balance.amount)}
                  </span>
                  <StatusBadge client:load status={account.status} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Audit Info -->
      <div class="mt-6 border-t border-gray-200 pt-6">
        <p class="text-xs text-gray-500">
          Client créé le {new Date(customer.created_at).toLocaleDateString('fr-FR', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
          })}
        </p>
      </div>
    </div>

    <!-- Actions -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <a
        href={`/accounts?customer_id=${id}`}
        class="rounded-lg border border-blue-200 bg-blue-50 p-4 hover:bg-blue-100 transition-colors"
      >
        <div class="text-2xl mb-2">💳</div>
        <h3 class="font-semibold text-gray-900">Comptes</h3>
        <p class="text-sm text-gray-600">Voir les comptes</p>
      </a>

      <button
        class="rounded-lg border border-green-200 bg-green-50 p-4 hover:bg-green-100 transition-colors"
      >
        <div class="text-2xl mb-2">✏️</div>
        <h3 class="font-semibold text-gray-900">Modifier</h3>
        <p class="text-sm text-gray-600">Éditer le profil</p>
      </button>

      <button
        class="rounded-lg border border-purple-200 bg-purple-50 p-4 hover:bg-purple-100 transition-colors"
      >
        <div class="text-2xl mb-2">📄</div>
        <h3 class="font-semibold text-gray-900">Documents</h3>
        <p class="text-sm text-gray-600">KYC et fichiers</p>
      </button>

      <button
        class="rounded-lg border border-red-200 bg-red-50 p-4 hover:bg-red-100 transition-colors"
      >
        <div class="text-2xl mb-2">🚫</div>
        <h3 class="font-semibold text-gray-900">Suspendre</h3>
        <p class="text-sm text-gray-600">Désactiver le client</p>
      </button>
    </div>
  </div>
</DashboardLayout>
