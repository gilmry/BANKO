---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.svelte";
---

<Base title="Accueil">
  <Header client:load />

  <!-- Hero Section -->
  <main id="main-content" data-testid="page-home" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <section data-testid="home-hero-section" class="py-16 sm:py-24 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-sm font-medium text-blue-700 mb-6">
        <span class="h-2 w-2 rounded-full bg-blue-600 animate-pulse"></span>
        Open Source · AGPL-3.0
      </div>
      <h1 data-testid="home-hero-title" class="text-5xl font-extrabold tracking-tight text-gray-900 sm:text-7xl">
        BANKO
      </h1>
      <p class="mt-4 text-xl text-blue-600 font-semibold">
        Core Banking Platform
      </p>
      <p class="mt-6 max-w-2xl mx-auto text-lg leading-8 text-gray-600">
        Plateforme bancaire open source conçue pour les banques tunisiennes.
        Transparente, auditable, conforme BCT/GAFI/Bâle III.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href="/login"
          data-testid="home-login-link"
          class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors"
        >
          Se connecter
        </a>
        <a
          href="/dashboard"
          data-testid="home-dashboard-link"
          class="rounded-lg bg-white px-6 py-3 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 transition-colors"
        >
          Tableau de bord →
        </a>
      </div>
    </section>

    <!-- KPI Banner -->
    <section data-testid="home-kpi-section" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="rounded-xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-200">
        <p class="text-3xl font-bold text-blue-600">24</p>
        <p class="mt-1 text-sm text-gray-600">Bounded Contexts</p>
      </div>
      <div class="rounded-xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-200">
        <p class="text-3xl font-bold text-green-600">1 930</p>
        <p class="mt-1 text-sm text-gray-600">Tests passés</p>
      </div>
      <div class="rounded-xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-200">
        <p class="text-3xl font-bold text-purple-600">95</p>
        <p class="mt-1 text-sm text-gray-600">Réf. réglementaires</p>
      </div>
      <div class="rounded-xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-200">
        <p class="text-3xl font-bold text-amber-600">350+</p>
        <p class="mt-1 text-sm text-gray-600">Endpoints API</p>
      </div>
    </section>

    <!-- Feature Grid -->
    <section data-testid="home-features-section" class="mb-16">
      <h2 data-testid="home-features-heading" class="text-2xl font-bold text-gray-900 text-center mb-10">Fonctionnalités principales</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">👥</div>
          <h3 class="font-semibold text-gray-900 text-lg">Gestion Clients</h3>
          <p class="mt-2 text-sm text-gray-600">KYC complet, segmentation, grouping économique, documents avec expiry tracking.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">💳</div>
          <h3 class="font-semibold text-gray-900 text-lg">Comptes & Opérations</h3>
          <p class="mt-2 text-sm text-gray-600">Multi-devises, nostro/vostro, limites, capitalisation d'intérêts, notifications de solde.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">💰</div>
          <h3 class="font-semibold text-gray-900 text-lg">Paiements</h3>
          <p class="mt-2 text-sm text-gray-600">PSD3, paiements instantanés, QR code, SWIFT MT103, virements SEPA.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">📈</div>
          <h3 class="font-semibold text-gray-900 text-lg">Crédit</h3>
          <p class="mt-2 text-sm text-gray-600">Revolving, syndication, restructuration, classification Circ. 91-24, IFRS 9.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">🛡️</div>
          <h3 class="font-semibold text-gray-900 text-lg">AML / Sanctions</h3>
          <p class="mt-2 text-sm text-gray-600">goAML/CTAF, 40 recommandations GAFI, travel rule R.16, batch screening.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">🏛️</div>
          <h3 class="font-semibold text-gray-900 text-lg">Finance Islamique</h3>
          <p class="mt-2 text-sm text-gray-600">Murabaha, Ijara, Sukuk, Zakat 2.5%, Sharia Board — Loi 2016-33.</p>
        </div>
      </div>
    </section>

    <!-- Compliance Badges -->
    <section data-testid="home-compliance-section" class="mb-16 text-center">
      <h2 data-testid="home-compliance-heading" class="text-2xl font-bold text-gray-900 mb-8">Conformité réglementaire</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <span class="inline-flex items-center rounded-full bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 ring-1 ring-blue-200">BCT</span>
        <span class="inline-flex items-center rounded-full bg-red-50 px-4 py-2 text-sm font-medium text-red-700 ring-1 ring-red-200">GAFI</span>
        <span class="inline-flex items-center rounded-full bg-green-50 px-4 py-2 text-sm font-medium text-green-700 ring-1 ring-green-200">Bâle III</span>
        <span class="inline-flex items-center rounded-full bg-purple-50 px-4 py-2 text-sm font-medium text-purple-700 ring-1 ring-purple-200">IFRS 9</span>
        <span class="inline-flex items-center rounded-full bg-amber-50 px-4 py-2 text-sm font-medium text-amber-700 ring-1 ring-amber-200">ISO 27001</span>
        <span class="inline-flex items-center rounded-full bg-teal-50 px-4 py-2 text-sm font-medium text-teal-700 ring-1 ring-teal-200">PCI DSS</span>
        <span class="inline-flex items-center rounded-full bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 ring-1 ring-indigo-200">INPDP</span>
        <span class="inline-flex items-center rounded-full bg-pink-50 px-4 py-2 text-sm font-medium text-pink-700 ring-1 ring-pink-200">Loi 2016-33</span>
        <span class="inline-flex items-center rounded-full bg-cyan-50 px-4 py-2 text-sm font-medium text-cyan-700 ring-1 ring-cyan-200">PSD3</span>
        <span class="inline-flex items-center rounded-full bg-orange-50 px-4 py-2 text-sm font-medium text-orange-700 ring-1 ring-orange-200">NCT</span>
      </div>
    </section>

    <!-- Architecture -->
    <section data-testid="home-architecture-section" class="mb-16 rounded-2xl bg-gray-900 p-8 sm:p-12 text-white">
      <h2 data-testid="home-architecture-heading" class="text-2xl font-bold mb-6">Architecture hexagonale en Rust</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-lg bg-gray-800 p-5">
          <p class="text-blue-400 font-mono text-sm mb-2">Domain Layer</p>
          <p class="text-gray-300 text-sm">Logique métier pure, zéro dépendance. Entités, value objects, invariants réglementaires.</p>
        </div>
        <div class="rounded-lg bg-gray-800 p-5">
          <p class="text-green-400 font-mono text-sm mb-2">Application Layer</p>
          <p class="text-gray-300 text-sm">Use cases, ports (traits async), DTOs. Orchestre le domain sans connaître l'infrastructure.</p>
        </div>
        <div class="rounded-lg bg-gray-800 p-5">
          <p class="text-amber-400 font-mono text-sm mb-2">Infrastructure Layer</p>
          <p class="text-gray-300 text-sm">PostgreSQL + SQLx, Actix-web handlers, adapters. Implémente les ports du domain.</p>
        </div>
      </div>
      <div class="mt-6 flex gap-4 text-sm">
        <a href="https://github.com/gilmry/BANKO" target="_blank" rel="noopener" data-testid="home-github-link" class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2 hover:bg-white/20 transition-colors">
          GitHub →
        </a>
        <a href="https://github.com/gilmry/koprogo" target="_blank" rel="noopener" data-testid="home-koprogo-link" class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2 hover:bg-white/20 transition-colors">
          Koprogo →
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer data-testid="home-footer" class="border-t border-gray-200 py-8 text-center text-sm text-gray-500">
      <p>© 2026 BANKO — ASBL BANKO (Tunisie) · Aivacore · Helpwise Bank</p>
      <p class="mt-1">Licence AGPL-3.0 · Code source ouvert et auditable</p>
    </footer>
  </main>
</Base>
