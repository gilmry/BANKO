---
import "../styles/global.css";
import "../styles/rtl.css";

interface Props {
  title: string;
  dir?: "ltr" | "rtl";
  lang?: string;
}

const { title, dir = "ltr", lang = "fr" } = Astro.props;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BANKO - Plateforme bancaire open source" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | BANKO</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-blue-700 focus:px-4 focus:py-2 focus:text-white"
    >
      Aller au contenu principal
    </a>
    <slot />
  </body>
</html>
