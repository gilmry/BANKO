# BANKO - Environment Variables
# Copy to .env and customize

# Database
DATABASE_URL=postgresql://banko:banko123@localhost:5432/banko_db
POSTGRES_DB=banko_db
POSTGRES_USER=banko
POSTGRES_PASSWORD=banko123

# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=debug
RUST_BACKTRACE=1

# Frontend
PUBLIC_API_URL=http://localhost/api/v1

# MinIO (S3-compatible storage)
S3_BUCKET=banko-dev
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
